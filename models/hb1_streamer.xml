    <!-- Slightly heavier to include streamer hardware -->
    <mass_inertia version="1" units="1" Mass="0.515" I_xx="0.024"
       I_yy="0.0013" I_zz="0.026" I_xz="0" />
    <sound version="1">
      <sample filename="electric.wav" type="1" pitchfactor="0.007" maxvolume="1" />
    </sound>
    <power units="1">
      <!-- 019 throttle tuning pass 4: F=6.5, CD_prof=0.14.
           Steady flight analysis: flight cruises 14m/s at 20-40% power.
           Idle glide should be ~10m/s not 16m/s — need more drag. -->
      <!-- 023: F 6.5→7.5 to match real cruise throttle (~60% vs sim 81%) -->
      <automagic F="7.5" V="11.1">
        <battery throttle_min="0">
          <automagic T="420" />
          <shaft J="0" brake="0">
            <propeller D="0.127" H="0.114" J="0" n_fold="5" />
            <engine>
              <automagic omega_p="2827" eta_opt="0.78" eta="0.7" />
            </engine>
          </shaft>
        </battery>
      </automagic>
    </power>
  </config>
