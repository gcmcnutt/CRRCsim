<?xml version="1.0" encoding="iso-8859-1" ?>
<CRRCSim_airplane version="2">
  <name>
    <en>HB1 (Streamer)</en>
  </name>
  <categories>
    <category>Powered combat</category>
    <category>Electric</category>
    <category>Flying wings</category>
    <category>Foamies</category>
  </categories>
  <description>
    <en>
HB1 configured to mimic the real test article towing a ~25 ft streamer.
Extra drag and slightly softer pitch authority to match the mushy feel seen in recent flights.
    </en>
  </description>
  <changelog>
    <change>
      <date>2025-03-10</date>
      <author>codex</author>
      <en>Add streamer drag + softer pitch to mirror real inflight behavior (≈11 m/s cruise).</en>
    </change>
  </changelog>
  <aero version="1" units="1">
    <!-- Reference speed lowered to match ~10-11 m/s cruise with streamer -->
    <ref chord="0.178" span="0.762" area="0.136" speed="11.0" />
    <misc Alpha_0="0" eta_loc="0.25" CG_arm="0.25" span_eff="0.82" />
    <!-- Pitch tuning history:
         Original: Cm_de=-0.22, Cm_q=-3.6
         018 attempt 1: Cm_de=-0.144, Cm_q=-5.5 → way too sluggish (39°/s)
         018 attempt 2: Cm_de=-0.19, Cm_q=-4.2 → still too sluggish
         019 analysis: sim pitch gain 44-61 deg/s/unit vs flight 72-122 = 0.5× flight
           Need MORE pitch authority, not less. Restore Cm_de toward original.
           Cm_q=-4.2 streamer damping seems reasonable — keep it.
         019 step 1: Cm_de=-0.24 (10% more than original -0.22) to close 0.5× gap.
         Roll: sim 504-583 vs flight 258-445 = 1.2-2× too fast.
           Cl_da 0.14→0.10 to reduce roll authority ~30%.
         For variations: Cm_q range -3.6 (no streamer) to -5.0 (25ft streamer). -->
    <m Cm_0="0.015" Cm_a="-0.55" Cm_q="-4.2" Cm_de="-0.24" />
    <!-- Lift/stall tuning (019 step 2):
         CL_max=1.2 + CL_drop=0.1 + CD_stall=0 meant the wing barely stalls.
         Full pitch just mushes through — NN exploits this for survivable looping.
         Real flying wing with streamer: stall is abrupt, deep stall = departure.
         CL_max 1.2→0.9 (earlier stall, real wing with streamer has less margin)
         CL_drop 0.1→0.5 (sharp lift loss post-stall, not gentle mush)
         CD_stall 0→0.10 (significant drag spike at stall — punishes full pitch)
         CL_min -0.9→-0.5 (inverted stall also sharper) -->
    <lift CL_0="0.18" CL_max="0.9" CL_min="-0.5" CL_a="4.7" CL_q="5.5"
       CL_de="0.55" CL_drop="0.5" CL_CD0="0.35" />
    <!-- Drag tuning history:
         Original: CD_prof=0.065 → sim Vmax≈32m/s (2× real 17m/s)
         018: CD_prof=0.18 → sim Vmax≈18m/s (good!) but drag curve too steep —
           sim forward accel crosses zero at 19m/s while flight stays positive.
         019 analysis: sim drag grows faster with speed than reality.
           Reduce CD_prof slightly (0.18→0.14) to flatten the curve.
           Compensate Vmax by slightly reducing thrust if needed.
           CD_ELsq=0.05 adds significant drag at full elevator — contributes to
           the degenerate full-pitch penalty being too low. Keep for now. -->
    <!-- CD_stall: 0→0.10 (post-stall drag penalty, makes full pitch costly) -->
    <!-- 019 throttle tuning: sim cruise was 76% power (flight=55%). F 5.0→6.5 gives
         headroom for NN throttle modulation. CD_prof 0.14→0.15 caps Vmax near 17 m/s. -->
    <drag CD_prof="0.15" Uexp_CD="-0.5" CD_stall="0.10" CD_CLsq="0.04" CD_AIsq="0.05"
       CD_ELsq="0.05" />
    <Y CY_b="-0.12" CY_p="-0.05" CY_r="0.08" CY_dr="0" CY_da="0.03" />
    <!-- Roll: 019 analysis sim 1.2-2× flight. Cl_da 0.14→0.10 (~30% reduction) -->
    <l Cl_b="-0.06" Cl_p="-0.55" Cl_r="0.05" Cl_dr="0" Cl_da="0.10" />
    <n Cn_b="0.03" Cn_p="-0.005" Cn_r="-0.015" Cn_dr="0"
       Cn_da="-0.010" />
  </aero>
  <config version="1">
    <descr_long>
      <en>HB1 tuned for streamer tow; slower cruise and mushier pitch to match logs.</en>
    </descr_long>
    <descr_short>
      <en>Streamer tuned</en>
    </descr_short>
    <!-- Slightly heavier to include streamer hardware -->
    <mass_inertia version="1" units="1" Mass="0.515" I_xx="0.024"
       I_yy="0.0013" I_zz="0.026" I_xz="0" />
    <sound version="1">
      <sample filename="electric.wav" type="1" pitchfactor="0.007" maxvolume="1" />
    </sound>
    <power units="1">
      <!-- 019 throttle tuning: F 5.0→6.5 so cruise at ~55% power (matching flight).
           CD_prof=0.15 caps Vmax near 17m/s. Flight: cruise 13m/s at 55%, Vmax 17. -->
      <automagic F="6.5" V="11.1">
        <battery throttle_min="0">
          <automagic T="420" />
          <shaft J="0" brake="0">
            <propeller D="0.127" H="0.114" J="0" n_fold="5" />
            <engine>
              <automagic omega_p="2827" eta_opt="0.78" eta="0.7" />
            </engine>
          </shaft>
        </battery>
      </automagic>
    </power>
  </config>
